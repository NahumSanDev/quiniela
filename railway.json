{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksJsonPath": ""
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "buildCommand": "cd backend && npm install && npx prisma generate && npm run build",
  "startCommand": "cd backend && npm start"
}