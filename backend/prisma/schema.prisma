generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  image         String?
  points        Int       @default(0)
  isAdmin       Boolean   @default(false)
  isGeneralAdmin Boolean  @default(false)
  mustChangePassword Boolean @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  predictions   Prediction[]
  groupMemberships GroupMember[]

  @@index([points, updatedAt])
}

model Group {
  id           String   @id @default(cuid())
  name         String
  code         String   @unique
  ownerId      String
  useExtraBets Boolean  @default(false)
  rules        Json?
  betRules     Json?
  createdAt    DateTime @default(now())

  members          GroupMember[]
  predictions      Prediction[]
  matchBetConfigs  GroupMatchBetConfig[]
}

model GroupMatchBetConfig {
  id              String  @id @default(cuid())
  groupId         String
  matchId         Int
  score           Boolean @default(true)
  totalGoals      Boolean @default(true)
  bothTeamsScore  Boolean @default(true)
  cleanSheet      Boolean @default(true)
  halfTimeScore   Boolean @default(true)
  firstGoalTeam   Boolean @default(true)
  firstGoalMinute Boolean @default(true)
  redCard         Boolean @default(true)
  totalCards      Boolean @default(true)
  extraTime       Boolean @default(true)
  penaltyShootout Boolean @default(true)
  rules         Json?

  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([groupId, matchId])
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      GroupRole @default(MEMBER)
  joinedAt  DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  group  Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Match {
  id                Int      @id @default(autoincrement())
  externalId        String   @unique
  homeTeam          String
  homeFlag          String
  awayTeam          String
  awayFlag          String
  startTime         DateTime
  homeScore         Int?
  awayScore         Int?
  status            MatchStatus @default(SCHEDULED)
  groupStage        String?
  isKnockout        Boolean  @default(false)
  halfTimeHomeScore Int?
  halfTimeAwayScore Int?
  firstGoalTeam     String?
  firstGoalMinute   Int?
  redCard           Boolean?
  totalCards        Int?
  extraTime         Boolean?
  penaltyShootout   Boolean?
  venueName         String?
  venueCity         String?
  venueCountry      String?
  betConfig         Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime  @updatedAt

  predictions        Prediction[]
  matchLogs          MatchLog[]
  groupBetConfigs    GroupMatchBetConfig[]

  @@index([startTime])
  @@index([status])
}

model Prediction {
  id                Int      @id @default(autoincrement())
  userId            String
  matchId           Int
  groupId           String?
  homeScore         Int      @default(0)
  awayScore         Int      @default(0)
  winner            String?
  isWinnerOnly      Boolean  @default(false)
  points            Int      @default(0)
  bonus             Boolean  @default(false)
  totalGoals        Int?
  bothTeamsScore    Boolean?
  cleanSheet        String?
  halfTimeHomeScore Int?
  halfTimeAwayScore Int?
  firstGoalTeam     String?
  firstGoalMinute   Int?
  redCard           Boolean?
  totalCards        Int?
  extraTime         Boolean?
  penaltyShootout   Boolean?
  extraPoints       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  group  Group? @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, matchId, groupId])
  @@index([userId, matchId])
  @@index([groupId])
  @@index([updatedAt])
}

model MatchLog {
  id          Int      @id @default(autoincrement())
  matchId     Int
  homeTeam    String?
  awayTeam    String?
  adminId     String?
  action      String
  changes     Json
  createdAt   DateTime @default(now())

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([createdAt])
}

enum GroupRole {
  MEMBER
  ADMIN
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}